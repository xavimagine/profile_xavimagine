---
interface Skill {
  name: string;
  icon: string;
}

interface Props {
  title: string;
  skills: Skill[];
}

const { title, skills } = Astro.props;
---

<div class="skill-card">
  <h3 class="card-title">{title}</h3>
  <div class="skills-grid">
    {skills.map((skill) => (
      <div class="skill-item">
        <div class="skill-icon" set:html={skill.icon} /><span>{skill.name}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .skill-card {
    background-color: #242421; 
    border-radius: 28px;
    padding: 1rem 1rem 2rem 2rem;;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-title {
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 600;
  }
    .skill-icon {
    width: 32px;
    height: 32px;
    }
    .skill-icon :global(svg) {
    width: 100%;
    height: 100%;
    }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
    gap: 1.5rem 1rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .skill-item span {
    color: #cccccc;
    font-size: 0.75rem;
  }
</style>
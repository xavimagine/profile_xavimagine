<style>
  .header {
    display: flex;
    align-items: center;
    flex-direction: column;
    padding: 1.4rem 0rem 2rem 0rem;
    background-color: #242421;
  }

  #logo  {
    width: 200px;
  }

  .nav{
    margin-top: 20px;
  }
  .nav a {
    color: #cccccc;
    margin-left: 1.5rem;
    text-decoration: none;
    font-family: Inter;
    font-size: 0.9rem;
  }
  #navphone{
    background-color: #242421;
    width: 334px;
    height: 55px;
    display: flex;
    align-items: center;
    justify-content: space-around; 
    border-radius: 39px;
    margin: 20px auto 0 auto;
    position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
    z-index: 1000;
  }
  #navphone a:hover svg {
    stroke: #00ff66;
  }
  #navphone a {
    margin-left: 0;
    display: flex;
  }
  .nav a:hover {
    color: #00ff66;
  }
</style>
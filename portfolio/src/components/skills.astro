---

<section id="habilidades" class="skills-section">
  <h2 class="section-title">
    <span class="green-number">02 /</span> Habilidades
  </h2>

  <div class="cards-grid">
    {skillsData.map((category) => (
      <Box title={category.title} skills={category.skills} />
    ))}
  </div>
</section>

<style>
  .skills-section {
    width: 80%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem; 
  }
span {
    color: #22C55E;
    font-size: 16px;
    font-family: 'Inter', sans-serif;
    margin-right: 8px;
    line-height: 1;
  }

  h2 {
    color: #F4F2EC;
    margin: 0;
    line-height: 1;
    font-size: 1.7rem;

  }
  .section-title {
    font-size: 1.5rem; 
    color: #ffffff;
    margin-bottom: 1.5rem;
  }

  .green-number {
    color: #00ff66;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr; 
    gap: 1.5rem;
  }

  /* TABLET / DESKTOP*/
  @media (min-width: 768px) {
    .skills-section {
      padding: 4rem 1rem;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 2.5rem;
    }

    .cards-grid {
      grid-template-columns: repeat(2, 1fr); 
      gap: 2rem;
    }
  }
</style>